IMG_NAME="chaoscrew-streaming"
RELEASE="bookworm"
TARGET_HOSTNAME="chaoscrew"
KEYBOARD_KEYMAP="de"
KEYBOARD_LAYOUT="German"
TIMEZONE_DEFAULT="Europe/Berlin"
LOCALE_DEFAULT="de_DE.UTF-8"
ENABLE_SSH=1
STAGE_LIST="stage0 stage1 stage2 stage-streaming"
DEPLOY_COMPRESSION=xz
COMPRESSION_LEVEL=6

# Server-Tech source: cloned into /opt/server-tech inside the chroot.
# Override via env when invoking pi-gen, e.g. SERVER_TECH_REF=v1.0.0 ./build-docker.sh
SERVER_TECH_REPO="${SERVER_TECH_REPO:-cccdemon/homecam-docker}"
SERVER_TECH_REF="${SERVER_TECH_REF:-main}"

# Disable NOOBS variant — single .img output is enough.
EXPORT_NOOBS=0

# Default first user (Pi OS Bookworm requires a user; RPi-Imager preconfig overrides this).
FIRST_USER_NAME="streamer"
FIRST_USER_PASS="raspberry"
DISABLE_FIRST_BOOT_USER_RENAME=0

# Image-name suffix
IMG_DATE="$(date +%Y%m%d)"
IMG_FILENAME="${IMG_NAME}-${IMG_DATE}"
