# Caddy reverse proxy + auto-TLS for public exposure.
# Activated only when PUBLIC_HOSTNAME is set in /opt/server-tech/.env
# (compose profile `public`).

{
    email {$PUBLIC_EMAIL}
}

{$PUBLIC_HOSTNAME} {
    encode gzip

    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }

    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }

    # MediaMTX HTTP API + HLS + WebRTC signaling.
    handle /v3/* {
        reverse_proxy mediamtx:8888
    }
    handle /webcam/whep* {
        reverse_proxy mediamtx:8555
    }
    handle /webcam {
        reverse_proxy mediamtx:8555
    }
    handle /webcam/*.m3u8 {
        reverse_proxy mediamtx:8889
    }
    handle /webcam/*.mp4 {
        reverse_proxy mediamtx:8889
    }

    # Web UI (nginx) at the root.
    handle {
        reverse_proxy web-ui:80
    }
}
