# /opt/server-tech/.env — Pi-runtime configuration.
# Default mode: LAN-only via mDNS (chaoscrew.local).
# To expose the stream publicly via Caddy + Let's-Encrypt:
#   1. Set PUBLIC_HOSTNAME and PUBLIC_EMAIL below
#   2. Point a DNS A record at the Pi's public IP
#   3. Forward TCP/80 + TCP/443 from your router to the Pi
#   4. sudo systemctl restart chaoscrew-streaming

CONTAINER_HOST=chaoscrew
CONTAINER_DOMAIN=chaoscrew.local

CAMERA_SOURCE=/dev/video0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=30
CAMERA_FORMAT=MJPEG

WEBRTC_PORT=8555
HTTP_PORT=8888
RTMP_PORT=1935
RTSP_PORT=8322
HLS_PORT=8889

VIDEO_CODEC=h264
VIDEO_BITRATE=8000

# Audio capture from the camera's built-in USB mic (C920 has stereo).
# Encoded as Opus 96k stereo (WebRTC-native, no transcode in MediaMTX).
# Toggle and `sudo systemctl restart chaoscrew-streaming` to apply.
AUDIO_ENABLED=true

DEBUG=false
MAX_CLIENTS=5
TIMEOUT=30s

MEDIAMTX_VERSION=1
RESTART_POLICY=unless-stopped
MEMORY_LIMIT=768m
CPUS_LIMIT=4

RECORD_HLS=false
RECORD_PATH=/recordings
RECORD_RETENTION=24h

AUTH_ENABLED=false

# Public access (TLS via Caddy). Leave empty for LAN-only mode.
PUBLIC_HOSTNAME=
PUBLIC_EMAIL=

STREAM_NAME=webcam
LOG_LEVEL=info
